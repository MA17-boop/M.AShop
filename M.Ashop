<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<title>Toko Vian PRO</title>

<style>
body {
  font-family: Arial;
  margin: 0;
  background: #0f172a;
  color: white;
}

header {
  background: #1e293b;
  padding: 15px;
  text-align: center;
}

nav button {
  margin: 5px;
  padding: 10px;
  border: none;
  border-radius: 10px;
  cursor: pointer;
}

.container {
  padding: 20px;
}

input {
  display: block;
  margin: 10px 0;
  padding: 10px;
  width: 100%;
  border-radius: 8px;
  border: none;
}

button {
  background: #22c55e;
  color: white;
}

.card {
  background: #1e293b;
  padding: 10px;
  margin: 10px 0;
  border-radius: 10px;
}

img {
  border-radius: 10px;
}
</style>
</head>

<body>

<header>
  <h1>Toko Vian 🛒</h1>
  <nav>
    <button onclick="showPage('home')">Home</button>
    <button onclick="showPage('tambah')">Tambah Produk</button>
    <button onclick="showPage('produk')">Daftar Produk</button>
  </nav>
</header>

<div class="container">

<!-- HOME -->
<div id="home">
  <h2>Selamat Datang 🚀</h2>
  <p>Ini website toko buatan Vian sendiri!</p>
</div>

<!-- TAMBAH -->
<div id="tambah" style="display:none;">
  <h2>Tambah Produk</h2>

  <input type="text" id="nama" placeholder="Nama Produk">
  <input type="number" id="harga" placeholder="Harga">
  <input type="file" id="gambar">

  <button onclick="simpan()">Simpan</button>
</div>

<!-- PRODUK -->
<div id="produk" style="display:none;">
  <h2>Daftar Produk</h2>
  <div id="list"></div>
</div>

</div>

<script>
let editIndex = null;

function showPage(page) {
  document.getElementById("home").style.display = "none";
  document.getElementById("tambah").style.display = "none";
  document.getElementById("produk").style.display = "none";

  document.getElementById(page).style.display = "block";

  if(page === "produk") tampilkan();
}

function simpan() {
  let nama = document.getElementById("nama").value;
  let harga = document.getElementById("harga").value;
  let file = document.getElementById("gambar").files[0];

  let reader = new FileReader();

  reader.onload = function() {
    let data = JSON.parse(localStorage.getItem("produk")) || [];

    if (editIndex !== null) {
      data[editIndex] = {
        nama: nama,
        harga: harga,
        gambar: reader.result
      };
      editIndex = null;
    } else {
      data.push({
        nama: nama,
        harga: harga,
        gambar: reader.result
      });
    }

    localStorage.setItem("produk", JSON.stringify(data));

    alert("Berhasil disimpan!");
    showPage("produk");
  };

  if (file) {
    reader.readAsDataURL(file);
  } else {
    alert("Pilih gambar!");
  }
}

function tampilkan() {
  let data = JSON.parse(localStorage.getItem("produk")) || [];
  let list = document.getElementById("list");
  list.innerHTML = "";

  data.forEach((p, i) => {
    list.innerHTML += `
      <div class="card">
        <img src="${p.gambar}" width="100"><br>
        <b>${p.nama}</b><br>
        Rp ${p.harga}<br><br>
        <button onclick="edit(${i})">Edit</button>
        <button onclick="hapus(${i})">Hapus</button>
      </div>
    `;
  });
}

function hapus(i) {
  let data = JSON.parse(localStorage.getItem("produk")) || [];
  data.splice(i, 1);
  localStorage.setItem("produk", JSON.stringify(data));
  tampilkan();
}

function edit(i) {
  let data = JSON.parse(localStorage.getItem("produk")) || [];
  let p = data[i];

  document.getElementById("nama").value = p.nama;
  document.getElementById("harga").value = p.harga;

  editIndex = i;
  showPage("tambah");
}
</script>

</body>
</html>